{
  "manifest_version": 3,
  "name": "Store Sync WhatsApp Sender",
  "version": "1.19",
  "description": "Change cursor style and start WhatsApp chats from a sidebar.",
  "permissions": ["scripting", "activeTab", "tabs"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://localhost:3000/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open WhatsApp Sidebar",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"]
    }
  ]
}
